	"semanticTokenColors": {
		"function": "#adb6e4",
		"variable": "#eeee99",
		"string": "#acc6c6",
		"number": "#10de18",
		"class": "#ff6b6b",
		"keyword": "#de82ad",
		"type": "#cc9731",
		"comment": "#536060"
