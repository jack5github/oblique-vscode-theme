				"support.variable.property",
				"entity.name.tag.localname",
				"entity.name.tag.yaml"
			],
			"settings": {
				"foreground": "#eeee99"
			}
		},
		{
			"scope": "markup.italic",
			"settings": {
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"constant.other.caps",
				"support.variable.magic",
				"variable.other.constant",
				"support.constant"
			],
			"settings": {
				"foreground": "#99e868"
