			"settings": {
				"foreground": "#adb6e4"
			}
		},
		{
			"scope": [
				"entity.name.function.python",
				"meta.definition.function",
				"meta.definition.method",
				"entity.name.function.lua"
			],
			"settings": {
				"fontStyle": "bold"
			}
		},
		{
			"scope": "markup.underline.link",
			"settings": {
				"foreground": "#ff7e50"
			}
		},
		{
			"scope": [
