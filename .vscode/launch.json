{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "New Window with VSCode Theme",
			"type": "extensionHost",
			"request": "launch",
			"args": ["--extensionDevelopmentPath=${workspaceFolder}"]
		},
		{
			"name": "Generate VSCode Themes",
			"type": "node",
			"request": "launch",
			"cwd": "${workspaceFolder}/src",
			"program": "generate.js",
			"args": ["vscode", ".."]
		}
	]
}
